---
import Layout from "../layouts/Layout.astro";
import "../styles/site.css";
const BASE = import.meta.env.BASE_URL;
---

<Layout
  title="Boutique | Atelier Prestige Luxembourg"
  description="Créations artisanales personnalisées: mascotas, baby shower, mémorias, personnalisation. Pièces uniques au Luxembourg."
  lang="fr"
>

<style is:inline>
  .filter-btn.active{border-color:#d4af37!important;color:#d4af37!important;background:rgba(212,175,55,.07)}
  #product-grid article img{transition:transform .5s ease}
  #product-grid article:hover img{transform:scale(1.06)}
  .line-clamp-2{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  @keyframes pulse-gold{0%,100%{box-shadow:0 0 0 0 rgba(212,175,55,.4)}50%{box-shadow:0 0 0 8px rgba(212,175,55,0)}}
  #cart-toggle.pulse{animation:pulse-gold .6s ease}
  .scrollbar-hide{scrollbar-width:none;-ms-overflow-style:none}
  .scrollbar-hide::-webkit-scrollbar{display:none}
  .qty-btn{width:28px;height:28px;border:1px solid #252525;color:#666;display:flex;align-items:center;justify-content:center;font-size:16px;line-height:1;transition:all .2s;cursor:pointer;background:transparent}
  .qty-btn:hover{border-color:#d4af37;color:#d4af37}
  @keyframes slide-in{from{transform:translateY(-10px);opacity:0}to{transform:translateY(0);opacity:1}}
  .toast{animation:slide-in .25s ease}
  #mobile-menu{display:none}
  #mobile-menu.open{display:flex}
  .skeleton{background:linear-gradient(90deg,#1a1a1a 25%,#252525 50%,#1a1a1a 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
  @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
</style>

<!-- TOAST -->
<div id="toast" class="toast fixed top-24 right-5 z-[70] bg-[#1a1a1a] border border-[#d4af37]/30 text-white text-xs px-4 py-3 hidden max-w-xs">
  <span id="toast-msg"></span>
</div>

<!-- NAV -->
<nav class="fixed top-0 w-full z-50 border-b border-white/5 backdrop-blur-md bg-[#0d0d0d]/90 h-20">
  <div class="flex justify-between items-center h-full px-6 max-w-7xl mx-auto">
    <a href={`${BASE}`} class="text-white font-light tracking-[0.2em] text-sm uppercase">Atelier Prestige</a>
    <div class="hidden md:flex gap-8 items-center">
      <a href={`${BASE}#expertise`} class="text-[10px] tracking-[0.2em] uppercase text-white/40 hover:text-white/80 transition-colors">Expertise</a>
      <a href={`${BASE}#b2b`}       class="text-[10px] tracking-[0.2em] uppercase text-white/40 hover:text-white/80 transition-colors">B2B</a>
      <a href={`${BASE}#contact`}   class="text-[10px] tracking-[0.2em] uppercase text-white/40 hover:text-white/80 transition-colors">Contact</a>
      <a href={`${BASE}boutique`}   class="text-[10px] tracking-[0.2em] uppercase text-[#d4af37] border border-[#d4af37]/40 px-4 py-2 hover:bg-[#d4af37]/10 transition-colors">Boutique</a>
    </div>
    <div class="flex items-center gap-3">
      <a href={`${BASE}#contact`} class="hidden md:block text-[9px] tracking-[0.25em] uppercase bg-white/5 text-white/60 px-4 py-2 hover:bg-white/10 border border-white/10 transition-colors">Devis</a>
      <!-- Mobile menu button -->
      <button id="nav-toggle" class="md:hidden text-white/60 hover:text-white w-8 h-8 flex items-center justify-center" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="absolute top-20 left-0 right-0 bg-[#0d0d0d] border-b border-white/5 flex-col px-6 py-4 gap-4 md:hidden">
    <a href={`${BASE}#expertise`} class="text-[10px] tracking-[0.2em] uppercase text-white/40 py-2">Expertise</a>
    <a href={`${BASE}#b2b`}       class="text-[10px] tracking-[0.2em] uppercase text-white/40 py-2">B2B</a>
    <a href={`${BASE}#contact`}   class="text-[10px] tracking-[0.2em] uppercase text-white/40 py-2">Contact</a>
    <a href={`${BASE}boutique`}   class="text-[10px] tracking-[0.2em] uppercase text-[#d4af37] py-2">Boutique</a>
    <a href={`${BASE}#contact`}   class="text-[9px] tracking-[0.25em] uppercase text-white/60 py-2">Devis personnalisé</a>
  </div>
</nav>

<main class="min-h-screen bg-[#0d0d0d]">

  <!-- HERO -->
  <section class="pt-36 pb-16 px-6 max-w-7xl mx-auto text-center">
    <span class="text-[#d4af37] tracking-[0.4em] uppercase text-[10px] font-medium block mb-5 opacity-80">Atelier × WeLuxEvents · Luxembourg</span>
    <h1 class="text-5xl md:text-7xl font-light text-white mb-6 leading-none tracking-tight">La Boutique</h1>
    <p class="text-[#555] text-base max-w-lg mx-auto leading-relaxed mb-4">
      Broderie · Gravure laser · Découpe vinyle<br>
      <span class="text-[#d4af37]/60 text-sm italic font-light">Cosas únicas para momentos que no se olvidan</span>
    </p>
    <div class="flex flex-wrap justify-center gap-4 text-[#333] text-[9px] tracking-widest uppercase mt-6">
      <span>🐾 Mascotas</span><span>·</span>
      <span>👶 Baby Shower</span><span>·</span>
      <span>💛 Mémorias</span><span>·</span>
      <span>✨ Personnalisation</span>
    </div>
  </section>

  <!-- CATEGORY FILTERS -->
  <div class="sticky top-20 z-40 bg-[#0d0d0d]/97 backdrop-blur-md border-b border-white/5 py-4 px-4">
    <div class="max-w-7xl mx-auto flex gap-2 overflow-x-auto scrollbar-hide pb-1">
      <button data-cat="all"      class="filter-btn active px-5 py-2 text-[9px] tracking-[0.2em] uppercase border whitespace-nowrap transition-all cursor-pointer border-[#d4af37] text-[#d4af37]">Tout</button>
      <button data-cat="pets"     class="filter-btn px-5 py-2 text-[9px] tracking-[0.2em] uppercase border whitespace-nowrap transition-all cursor-pointer border-white/15 text-white/35 hover:border-[#d4af37] hover:text-[#d4af37]">🐾 Mascotas</button>
      <button data-cat="baby"     class="filter-btn px-5 py-2 text-[9px] tracking-[0.2em] uppercase border whitespace-nowrap transition-all cursor-pointer border-white/15 text-white/35 hover:border-[#d4af37] hover:text-[#d4af37]">👶 Baby Shower</button>
      <button data-cat="memories" class="filter-btn px-5 py-2 text-[9px] tracking-[0.2em] uppercase border whitespace-nowrap transition-all cursor-pointer border-white/15 text-white/35 hover:border-[#d4af37] hover:text-[#d4af37]">💛 Mémorias</button>
      <button data-cat="custom"   class="filter-btn px-5 py-2 text-[9px] tracking-[0.2em] uppercase border whitespace-nowrap transition-all cursor-pointer border-white/15 text-white/35 hover:border-[#d4af37] hover:text-[#d4af37]">✨ Personnalisation</button>
    </div>
  </div>

  <!-- PRODUCT GRID -->
  <div class="max-w-7xl mx-auto px-4 mt-10 pb-36">
    <p id="product-count" class="text-[#333] text-[9px] tracking-widest uppercase mb-6 px-2"></p>
    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      <!-- Skeleton loaders -->
      <div class="skeleton border border-[#1e1e1e] h-80 rounded-none"></div>
      <div class="skeleton border border-[#1e1e1e] h-80 rounded-none"></div>
      <div class="skeleton border border-[#1e1e1e] h-80 rounded-none"></div>
      <div class="skeleton border border-[#1e1e1e] h-80 rounded-none"></div>
    </div>
  </div>
</main>

<!-- OVERLAY -->
<div id="cart-overlay" class="fixed inset-0 bg-black/60 z-50 hidden backdrop-blur-sm cursor-pointer"></div>

<!-- CART DRAWER -->
<aside id="cart-drawer"
  style="transform:translateX(100%);transition:transform .32s cubic-bezier(.4,0,.2,1)"
  class="fixed top-0 right-0 h-full w-full max-w-sm bg-[#0f0f0f] border-l border-white/5 z-[51] flex flex-col">
  <div class="flex items-center justify-between px-6 py-5 border-b border-white/5">
    <div>
      <h2 class="text-white text-[10px] tracking-[0.3em] uppercase">Votre Panier</h2>
      <span id="cart-label" class="text-[#444] text-[9px]">0 articles</span>
    </div>
    <button id="cart-close" class="text-[#444] hover:text-white transition-colors text-2xl w-8 h-8 flex items-center justify-center leading-none">&times;</button>
  </div>
  <div id="cart-items" class="flex-1 overflow-y-auto p-6 space-y-4">
    <p class="text-[#333] text-center text-sm py-16">Votre panier est vide.</p>
  </div>
  <div class="p-6 border-t border-white/5 space-y-4">
    <div class="flex justify-between items-center">
      <span class="text-[#444] text-[9px] tracking-widest uppercase">Total</span>
      <span id="cart-total" class="text-[#d4af37] text-xl font-light">€0.00</span>
    </div>
    <!-- WhatsApp quick order -->
    <a id="whatsapp-btn" href="#" target="_blank" rel="noopener"
      class="flex items-center justify-center gap-2 w-full border border-[#25d366]/30 text-[#25d366] text-[9px] tracking-[0.2em] uppercase py-3 hover:bg-[#25d366]/10 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Commander via WhatsApp
    </a>
    <button id="checkout-btn" class="w-full bg-[#d4af37] text-black text-[10px] tracking-[0.25em] uppercase font-medium py-4 hover:bg-[#e8c84a] transition-colors active:scale-[.98]">
      Passer commande
    </button>
  </div>
</aside>

<!-- FLOATING CART BUTTON -->
<button id="cart-toggle"
  class="fixed bottom-8 right-6 z-40 w-14 h-14 bg-[#d4af37] rounded-full flex items-center justify-center shadow-2xl hover:bg-[#e8c84a] transition-all hover:scale-105 active:scale-95">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
  </svg>
  <span id="cart-badge" style="display:none" class="absolute -top-1 -right-1 min-w-[20px] h-5 bg-black text-[#d4af37] text-[9px] font-bold rounded-full flex items-center justify-center px-1">0</span>
</button>

<!-- PRODUCT DETAIL MODAL -->
<div id="detail-modal" style="display:none"
  class="fixed inset-0 bg-black/90 z-[60] items-center justify-center p-4 backdrop-blur-md overflow-y-auto">
  <div class="bg-[#0f0f0f] border border-white/10 w-full max-w-2xl relative my-4 flex flex-col md:flex-row overflow-hidden">
    <button id="detail-close" class="absolute top-4 right-4 z-10 text-[#444] hover:text-white text-2xl w-8 h-8 flex items-center justify-center leading-none">&times;</button>
    <div class="md:w-1/2 aspect-square bg-[#1a1a1a] flex-shrink-0">
      <img id="detail-img" src="" alt="" class="w-full h-full object-cover">
    </div>
    <div class="p-6 flex flex-col gap-4 flex-1">
      <span id="detail-cat" class="text-[#d4af37]/50 text-[8px] tracking-[0.2em] uppercase"></span>
      <h3 id="detail-name" class="text-white text-xl font-light leading-snug"></h3>
      <p id="detail-desc" class="text-[#555] text-sm leading-relaxed flex-1"></p>
      <div class="text-[#333] text-[9px] tracking-widest uppercase">
        Machine: <span id="detail-machine" class="text-[#555]"></span>
      </div>
      <div class="flex items-center justify-between pt-2 border-t border-white/5">
        <span id="detail-price" class="text-[#d4af37] text-2xl font-light"></span>
        <button id="detail-add-btn" class="bg-[#d4af37] text-black text-[9px] tracking-[0.2em] uppercase font-medium px-6 py-3 hover:bg-[#e8c84a] transition-colors" data-id="">
          + Ajouter au panier
        </button>
      </div>
    </div>
  </div>
</div>

<!-- CHECKOUT MODAL -->
<div id="checkout-modal" style="display:none"
  class="fixed inset-0 bg-black/85 z-[60] items-start justify-center p-4 pt-8 backdrop-blur-md overflow-y-auto">
  <div class="bg-[#0f0f0f] border border-white/10 w-full max-w-md p-8 relative my-4">
    <button id="checkout-close" class="absolute top-5 right-5 text-[#444] hover:text-white text-2xl w-8 h-8 flex items-center justify-center leading-none">&times;</button>
    <span class="text-[#d4af37] text-[9px] tracking-[0.3em] uppercase block mb-3">Commander</span>
    <h2 class="text-white text-2xl font-light mb-2">Finaliser</h2>
    <p class="text-[#444] text-sm mb-7">Notre équipe vous contacte sous 24h pour confirmer les détails de personnalisation.</p>
    <form id="order-form" class="space-y-4">
      <div>
        <label class="text-[#444] text-[9px] tracking-[0.2em] uppercase block mb-2">Nom complet *</label>
        <input name="name" required type="text" placeholder="Jean Dupont"
          class="w-full bg-[#1a1a1a] border border-[#252525] focus:border-[#d4af37]/40 text-white px-4 py-3 text-sm outline-none transition-colors">
      </div>
      <div>
        <label class="text-[#444] text-[9px] tracking-[0.2em] uppercase block mb-2">Email *</label>
        <input name="email" required type="email" placeholder="jean@example.lu"
          class="w-full bg-[#1a1a1a] border border-[#252525] focus:border-[#d4af37]/40 text-white px-4 py-3 text-sm outline-none transition-colors">
      </div>
      <div>
        <label class="text-[#444] text-[9px] tracking-[0.2em] uppercase block mb-2">WhatsApp / Téléphone</label>
        <input name="phone" type="tel" placeholder="+352 XXX XXX"
          class="w-full bg-[#1a1a1a] border border-[#252525] focus:border-[#d4af37]/40 text-white px-4 py-3 text-sm outline-none transition-colors">
      </div>
      <div>
        <label class="text-[#444] text-[9px] tracking-[0.2em] uppercase block mb-2">Détails de personnalisation</label>
        <textarea name="notes" rows="3" placeholder="Prénom à broder, couleurs, photo à envoyer…"
          class="w-full bg-[#1a1a1a] border border-[#252525] focus:border-[#d4af37]/40 text-white px-4 py-3 text-sm outline-none transition-colors resize-none"></textarea>
      </div>
      <div id="order-summary" class="bg-[#161616] border border-[#252525] p-4 space-y-2 text-xs text-[#666]"></div>
      <button type="submit" id="submit-btn"
        class="w-full bg-[#d4af37] text-black text-[10px] tracking-[0.25em] uppercase font-medium py-4 hover:bg-[#e8c84a] transition-colors mt-2 disabled:opacity-40 disabled:cursor-not-allowed">
        Envoyer la commande
      </button>
      <p class="text-[#2a2a2a] text-[9px] text-center">Paiement confirmé avec notre équipe · Livraison Luxembourg</p>
    </form>
    <div id="order-success" class="hidden text-center py-10">
      <div class="text-5xl mb-5 text-[#d4af37]">✓</div>
      <h3 class="text-white text-xl font-light mb-3">Commande envoyée !</h3>
      <p id="order-id-display" class="text-[#d4af37]/60 text-[9px] tracking-widest uppercase mb-3"></p>
      <p class="text-[#555] text-sm leading-relaxed mb-6">Nous vous contacterons sous 24h pour confirmer votre commande et discuter des détails de personnalisation.</p>
      <button id="success-close" class="text-[#d4af37] text-[9px] tracking-widest uppercase underline underline-offset-4">Continuer les achats</button>
    </div>
  </div>
</div>


