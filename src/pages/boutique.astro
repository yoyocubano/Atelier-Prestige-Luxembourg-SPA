   desc:'Planche à découper bois massif avec dédicace gravée.'},
  {id:'r3',cat:'memories',name:'Cojín bordado personalizado',price:55,machine:'Bordadora',
   img:'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&q=80&fit=crop',
   desc:'Coussin 45×45cm. Citation ou texte brodé en fil doré. Housse lavable.'},
  {id:'r4',cat:'memories',name:'Marco foto con texto grabado',price:42,machine:'Láser',
   img:'https://images.unsplash.com/photo-1416339306562-f3d12fefd36f?w=600&q=80&fit=crop',
   desc:'Cadre bois 20×25cm. Message gravé laser. Votre photo + votre texte.'},
  {id:'r5',cat:'memories',name:'Álbum aniversario grabado',price:75,machine:'Láser',
   img:'https://images.unsplash.com/photo-1518568814500-bf0f8d125f46?w=600&q=80&fit=crop',
   desc:'Album 30×30cm couverture bois gravée. Noms + date. 20 pages papier premium.'},
  {id:'r6',cat:'memories',name:'Plaque souvenir Luxembourg',price:38,machine:'Láser',
   img:'https://images.unsplash.com/photo-1590677197960-4a85a80cdd67?w=600&q=80&fit=crop',
   desc:'Plaque bois/acrylique 15×10cm. Carte du Luxembourg + texte personnalisé.'},
  {id:'c1',cat:'custom',name:'Casquette brodée logo',price:29,machine:'Bordadora',
   img:'https://images.unsplash.com/photo-1588850561407-ed78c282e89b?w=600&q=80&fit=crop',
   desc:'Casquette 5 panneaux. Logo ou texte brodé haute précision.'},
  {id:'c2',cat:'custom',name:'Stickers vinilo empresa',price:16,machine:'Cortadora',
   img:'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?w=600&q=80&fit=crop',
   desc:'Stickers à votre logo découpés avec précision. Vinyle waterproof extérieur.'},
  {id:'c3',cat:'custom',name:'Kit corporatif x5',price:125,machine:'Bordadora + Sublimación',
   img:'https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80&fit=crop',
   desc:'5 pièces assorties: casquette + tasse + porte-clés. Team building.'},
  {id:'c4',cat:'custom',name:'Vinilo decorativo vitrine',price:35,machine:'Cortadora',
   img:'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=600&q=80&fit=crop',
   desc:'Vinyle découpé à vos dimensions avec votre logo.'},
  {id:'c5',cat:'custom',name:'Tarjetas die-cut personalizadas',price:20,machine:'Cortadora',
   img:'https://images.unsplash.com/photo-1607344645866-009c320b63e0?w=600&q=80&fit=crop',
   desc:'50 cartes découpées à votre forme de logo. Impression laser premium.'},
  {id:'c6',cat:'custom',name:'Termo grabado nombre + logo',price:38,machine:'Láser',
   img:'https://images.unsplash.com/photo-1535025639604-9a804c092faa?w=600&q=80&fit=crop',
   desc:'Thermos inox 500ml avec nom ou logo gravé laser. Cadeau entreprise premium.'},
];

const CAT_LABELS = {all:'Tout',pets:'🐾 Mascotas',baby:'👶 Baby Shower',memories:'💛 Mémorias',custom:'✨ Personnalisation'};
let products = [], cart = [], activeFilter = 'all';

try { cart = JSON.parse(localStorage.getItem('ap-cart')||'[]'); } catch {}

// ── TOAST ────────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const el = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  el.classList.remove('hidden');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.add('hidden'), 2200);
}

// ── LOAD PRODUCTS ────────────────────────────────────────────────────────────
async function loadProducts() {
  if (SHEET_ID) {
    try {
      const r = await fetch(`https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=Products&timestamp=${Date.now()}`);
      const t = await r.text();
      const j = JSON.parse(t.replace(/^[^{]+/, '').replace(/\);?\s*$/, ''));
      const rows = j.table.rows;
      if (rows && rows.length > 0) {
        products = rows.map((row, i) => ({
          id: row.c[0]?.v || `s${i}`,
          name: row.c[1]?.v || '',
          cat: row.c[2]?.v || 'custom',
          price: parseFloat(row.c[3]?.v) || 0,
          img: (row.c[4]?.v || '') + (row.c[4]?.v && !row.c[4].v.includes('?') ? '?w=600&q=80&fit=crop' : ''),
          desc: row.c[5]?.v || '',
          machine: row.c[6]?.v || '',
        }));
      } else { products = CATALOGUE; }
    } catch (e) { products = CATALOGUE; }
  } else { products = CATALOGUE; }
  updateFilterCounts();
  renderGrid();
}

// ── UPDATE FILTER BUTTON COUNTS ──────────────────────────────────────────────
function updateFilterCounts() {
  document.querySelectorAll('.filter-btn').forEach(btn => {
    const cat = btn.dataset.cat;
    const count = cat === 'all' ? products.length : products.filter(p => p.cat === cat).length;
    const label = CAT_LABELS[cat] || cat;
    btn.textContent = `${label} (${count})`;
  });
}

// ── RENDER GRID ──────────────────────────────────────────────────────────────
function renderGrid() {
  const list = activeFilter === 'all' ? products : products.filter(p => p.cat === activeFilter);
  document.getElementById('product-count').textContent = `${list.length} produit${list.length !== 1 ? 's' : ''}`;
  const grid = document.getElementById('product-grid');
  if (!list.length) {
    grid.innerHTML = '<div class="col-span-full py-24 text-center text-[#333] text-sm">Aucun produit dans cette catégorie.</div>';
    return;
  }
  grid.innerHTML = list.map(p => `
    <article class="border border-[#1e1e1e] hover:border-[#d4af37]/25 transition-all duration-300 bg-[#111] overflow-hidden group cursor-pointer" data-id="${p.id}">
      <div class="aspect-[4/3] overflow-hidden bg-[#1a1a1a]">
        <img src="${p.img}" alt="${p.name}" loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          onerror="this.src='https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=60'">
      </div>
      <div class="p-4">
        <span class="text-[#d4af37]/50 text-[8px] tracking-[0.2em] uppercase block mb-1">${CAT_LABELS[p.cat]||p.cat}</span>
        <h3 class="text-white text-sm font-light leading-snug mb-1">${p.name}</h3>
        <p class="text-[#444] text-xs leading-relaxed mb-3 line-clamp-2">${p.desc}</p>
        <div class="flex items-center justify-between">
          <span class="text-[#d4af37] font-medium">€${p.price}</span>
          <button class="add-btn border border-[#2a2a2a] hover:border-[#d4af37]/50 text-[#555] hover:text-[#d4af37] text-[8px] tracking-[0.15em] uppercase px-3 py-2 transition-all" data-id="${p.id}">+ Ajouter</button>
        </div>
      </div>
    </article>`).join('');

  // Article click → detail modal
  grid.querySelectorAll('article').forEach(a => a.addEventListener('click', e => {
    if (e.target.classList.contains('add-btn')) return;
    openDetail(a.dataset.id);
  }));
  grid.querySelectorAll('.add-btn').forEach(b => b.addEventListener('click', e => {
    e.stopPropagation();
    addToCart(b.dataset.id, b);
  }));
}

// ── DETAIL MODAL ─────────────────────────────────────────────────────────────
function openDetail(id) {
  const p = products.find(x => x.id === id); if (!p) return;
  document.getElementById('detail-img').src = p.img;
  document.getElementById('detail-img').alt = p.name;
  document.getElementById('detail-cat').textContent = CAT_LABELS[p.cat] || p.cat;
  document.getElementById('detail-name').textContent = p.name;
  document.getElementById('detail-desc').textContent = p.desc;
  document.getElementById('detail-machine').textContent = p.machine;
  document.getElementById('detail-price').textContent = `€${p.price}`;
  document.getElementById('detail-add-btn').dataset.id = p.id;
  const m = document.getElementById('detail-modal'); m.style.display = 'flex';
}
document.getElementById('detail-close').addEventListener('click', () => {
  document.getElementById('detail-modal').style.display = 'none';
});
document.getElementById('detail-add-btn').addEventListener('click', function() {
  addToCart(this.dataset.id);
  document.getElementById('detail-modal').style.display = 'none';
});

// ── CART ─────────────────────────────────────────────────────────────────────
function addToCart(id, btn) {
  const p = products.find(x => x.id === id); if (!p) return;
  const ex = cart.find(x => x.id === id);
  if (ex) ex.qty++;
  else cart.push({id:p.id, name:p.name, price:p.price, img:p.img, qty:1});
  saveCart(); renderCart();
  showToast(`✓ ${p.name.split(' ').slice(0,3).join(' ')} ajouté`);
  if (btn) {
    const orig = btn.textContent;
    btn.textContent = '✓'; btn.style.cssText = 'border-color:#d4af37;color:#d4af37';
    setTimeout(() => { btn.textContent = orig; btn.style.cssText = ''; }, 1500);
  }
  const t = document.getElementById('cart-toggle');
  t.classList.add('pulse'); setTimeout(() => t.classList.remove('pulse'), 700);
}
function changeQty(id, delta) {
  const item = cart.find(x => x.id === id); if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) cart = cart.filter(x => x.id !== id);
  saveCart(); renderCart();
}
function removeFromCart(id) { cart = cart.filter(x => x.id !== id); saveCart(); renderCart(); }
function saveCart() { try { localStorage.setItem('ap-cart', JSON.stringify(cart)); } catch {} }
function renderCart() {
  const total = cart.reduce((s,i) => s + i.price * i.qty, 0);
  const count = cart.reduce((s,i) => s + i.qty, 0);
  document.getElementById('cart-total').textContent = `€${total.toFixed(2)}`;
  document.getElementById('cart-label').textContent = `${count} article${count!==1?'s':''}`;
  const badge = document.getElementById('cart-badge');
  badge.textContent = count; badge.style.display = count ? 'flex' : 'none';

  // WhatsApp link
  const waText = encodeURIComponent(
    '🛍️ *Commande Atelier Prestige*\n\n' +
    cart.map(i => `• ${i.name} ×${i.qty} — €${(i.price*i.qty).toFixed(2)}`).join('\n') +
    `\n\n*Total: €${total.toFixed(2)}*\n\nMerci de confirmer ma commande!`
  );
  document.getElementById('whatsapp-btn').href = `https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`;

  const el = document.getElementById('cart-items');
  if (!cart.length) {
    el.innerHTML = '<p class="text-[#333] text-center text-sm py-16">Votre panier est vide.</p>';
    return;
  }
  el.innerHTML = cart.map(i => `
    <div class="flex gap-3 pb-4 border-b border-[#1e1e1e] last:border-0 last:pb-0">
      <img src="${i.img}" alt="${i.name}" class="w-16 h-16 object-cover bg-[#1a1a1a] flex-shrink-0 cursor-pointer"
        onerror="this.src='https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=100'"
        onclick="openDetail('${i.id}')">
      <div class="flex-1 min-w-0">
        <p class="text-white text-xs leading-snug mb-2 line-clamp-2">${i.name}</p>
        <div class="flex items-center gap-2">
          <button class="qty-btn" onclick="changeQty('${i.id}',-1)">−</button>
          <span class="text-[#666] text-xs w-5 text-center">${i.qty}</span>
          <button class="qty-btn" onclick="changeQty('${i.id}',1)">+</button>
          <span class="text-[#d4af37] text-sm ml-2">€${(i.price*i.qty).toFixed(2)}</span>
        </div>
      </div>
      <button class="rm text-[#333] hover:text-red-400 transition-colors text-xl w-7 h-7 flex items-center justify-center flex-shrink-0 leading-none" onclick="removeFromCart('${i.id}')">&times;</button>
    </div>`).join('');
}

// ── UI ────────────────────────────────────────────────────────────────────────
function openDrawer() {
  document.getElementById('cart-drawer').style.transform = 'translateX(0)';
  document.getElementById('cart-overlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}
function closeDrawer() {
  document.getElementById('cart-drawer').style.transform = 'translateX(100%)';
  document.getElementById('cart-overlay').classList.add('hidden');
  document.body.style.overflow = '';
}

document.getElementById('cart-toggle').addEventListener('click', openDrawer);
document.getElementById('cart-close').addEventListener('click', closeDrawer);
document.getElementById('cart-overlay').addEventListener('click', () => {
  closeDrawer();
  document.getElementById('detail-modal').style.display = 'none';
});

// Mobile nav
document.getElementById('nav-toggle').addEventListener('click', () => {
  document.getElementById('mobile-menu').classList.toggle('open');
});

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(btn => btn.addEventListener('click', () => {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active'); activeFilter = btn.dataset.cat; renderGrid();
}));

// Escape key closes modals
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeDrawer();
    document.getElementById('detail-modal').style.display = 'none';
    document.getElementById('checkout-modal').style.display = 'none';
  }
});

// ── CHECKOUT ──────────────────────────────────────────────────────────────────
document.getElementById('checkout-btn').addEventListener('click', () => {
  if (!cart.length) { showToast('Votre panier est vide.'); return; }
  closeDrawer();
  const total = cart.reduce((s,i) => s+i.price*i.qty, 0);
  document.getElementById('order-summary').innerHTML =
    cart.map(i => `<div class="flex justify-between"><span class="line-clamp-1 flex-1 mr-4">${i.name} <span class="text-[#444]">×${i.qty}</span></span><span class="text-[#d4af37] whitespace-nowrap">€${(i.price*i.qty).toFixed(2)}</span></div>`).join('') +
    `<div class="flex justify-between border-t border-[#2a2a2a] pt-2 mt-1 font-medium text-white"><span>Total</span><span class="text-[#d4af37]">€${total.toFixed(2)}</span></div>`;
  const m = document.getElementById('checkout-modal'); m.style.display = 'flex';
});
document.getElementById('checkout-close').addEventListener('click', () => {
  document.getElementById('checkout-modal').style.display = 'none';
});

document.getElementById('order-form').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Envoi en cours…'; btn.disabled = true;
  const fd = new FormData(e.target);
  const orderId = 'AP-' + Date.now().toString(36).toUpperCase();
  const order = {
    order_id: orderId,
    timestamp: new Date().toISOString(),
    name: fd.get('name'), email: fd.get('email'),
    phone: fd.get('phone')||'', notes: fd.get('notes')||'',
    items: JSON.stringify(cart.map(i => `${i.name} x${i.qty} @€${i.price}`)),
    total: cart.reduce((s,i) => s+i.price*i.qty, 0).toFixed(2)
  };
  if (APPS_SCRIPT_URL) {
    try {
      await fetch(APPS_SCRIPT_URL, {
        method:'POST', mode:'no-cors',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify(order)
      });
    } catch {}
  }
  document.getElementById('order-id-display').textContent = `Réf: ${orderId}`;
  document.getElementById('order-form').classList.add('hidden');
  document.getElementById('order-success').classList.remove('hidden');
  cart = []; saveCart(); renderCart();
});

document.getElementById('success-close').addEventListener('click', () => {
  document.getElementById('checkout-modal').style.display = 'none';
  document.getElementById('order-form').classList.remove('hidden');
  document.getElementById('order-success').classList.add('hidden');
  document.getElementById('order-form').reset();
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Envoyer la commande'; btn.disabled = false;
});

// ── INIT ──────────────────────────────────────────────────────────────────────
renderCart();
loadProducts();
</script>

</Layout>
