---
import Layout from "../layouts/Layout.astro";
import "../styles/site.css";
const BASE = import.meta.env.BASE_URL;
---

<Layout
  title="La Boutique — Atelier Prestige Luxembourg"
  description="Créations artisanales personnalisées: mascotas, baby shower, mémorias, personnalisation. Pièces uniques au Luxembourg."
  lang="fr"
>

<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400;500&family=EB+Garamond:ital,wght@0,400;1,300&display=swap');

  :root {
    --gold: #d4af37;
    --gold-dim: rgba(212,175,55,0.4);
    --bg: #080808;
    --surface: #0f0f0f;
    --surface2: #161616;
    --border: rgba(255,255,255,0.055);
    --text: #f0ebe2;
    --muted: #555;
    --dim: #2a2a2a;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html { scroll-behavior: auto; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  body.ready { opacity: 1; }

  /* ── GRAIN TEXTURE ── */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none;
    z-index: 9998;
    opacity: 0.032;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 128px 128px;
  }

  /* ── CUSTOM CURSOR ── */
  #cursor-ring {
    position: fixed;
    top: 0; left: 0;
    width: 38px; height: 38px;
    border: 1px solid var(--gold);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    transition: width 0.25s, height 0.25s, border-color 0.25s, opacity 0.25s;
  }
  #cursor-dot {
    position: fixed;
    top: 0; left: 0;
    width: 5px; height: 5px;
    background: var(--gold);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    transform: translate(-2.5px, -2.5px);
  }
  body.cursor-hover #cursor-ring {
    width: 54px; height: 54px;
    border-color: rgba(212,175,55,0.5);
  }
  body.cursor-hover #cursor-dot { opacity: 0; }
  @media (hover: none) { #cursor-ring, #cursor-dot { display: none; } }

  /* ── SCROLL PROGRESS ── */
  #scroll-progress {
    position: fixed;
    top: 0; left: 0;
    height: 1px;
    width: 0%;
    background: var(--gold);
    z-index: 9997;
    will-change: width;
    transition: width 0.05s linear;
  }

  /* ── NAV ── */
  #main-nav {
    transition: padding 0.4s ease, background 0.4s ease, backdrop-filter 0.4s ease, border-color 0.4s ease;
  }
  #main-nav.scrolled {
    background: rgba(8,8,8,0.97) !important;
    border-bottom-color: rgba(255,255,255,0.08) !important;
    backdrop-filter: blur(20px) !important;
  }
  #main-nav .nav-inner {
    transition: height 0.4s ease;
  }
  #main-nav.scrolled .nav-inner {
    height: 60px !important;
  }

  /* ── HERO ── */
  #hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  #hero::before {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--gold-dim));
  }
  .hero-eyebrow {
    font-size: 9px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0;
    margin-bottom: 28px;
    font-weight: 300;
  }
  .hero-title-wrap {
    overflow: hidden;
    line-height: 1;
    margin-bottom: 28px;
  }
  .hero-title {
    font-size: clamp(56px, 10vw, 128px);
    font-weight: 100;
    letter-spacing: -0.02em;
    color: var(--text);
    display: block;
    font-family: 'Outfit', sans-serif;
  }
  .hero-char { display: inline-block; transform: translateY(110%); }
  .hero-line {
    width: 0%;
    height: 1px;
    background: var(--border);
    margin: 0 auto 28px;
    max-width: 480px;
  }
  .hero-subtitle {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 17px;
    font-weight: 300;
    font-style: italic;
    color: var(--muted);
    letter-spacing: 0.02em;
    opacity: 0;
    margin-bottom: 48px;
  }
  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    opacity: 0;
  }
  .hero-tag {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--dim);
    padding: 8px 20px;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }
  .hero-tag:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
  }

  /* ── FLOATING BG ELEMENTS ── */
  .hero-bg-num {
    position: absolute;
    font-size: clamp(120px, 20vw, 240px);
    font-weight: 100;
    color: rgba(255,255,255,0.018);
    pointer-events: none;
    font-family: 'Outfit', sans-serif;
    letter-spacing: -0.05em;
    user-select: none;
  }

  /* ── FILTER BAR ── */
  #filter-bar {
    position: sticky;
    top: 60px;
    z-index: 40;
    background: rgba(8,8,8,0.96);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0;
    transition: top 0.4s ease;
  }
  #filter-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    position: relative;
  }
  #filter-inner::-webkit-scrollbar { display: none; }
  .filter-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--muted);
    padding: 18px 20px;
    white-space: nowrap;
    border: none;
    background: transparent;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
    border-bottom: 1.5px solid transparent;
  }
  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 1.5px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .filter-btn.active { color: var(--gold); }
  .filter-btn.active::after { transform: scaleX(1); }
  .filter-btn:hover:not(.active) { color: rgba(240,235,226,0.7); }

  /* ── PRODUCT CARDS ── */
  .product-card {
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
    cursor: pointer;
    transform-style: preserve-3d;
    will-change: transform;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
    opacity: 0;
    transform: translateY(30px);
  }
  .product-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease, transform 0.6s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .product-card:hover {
    border-color: rgba(212,175,55,0.22);
    box-shadow: 0 24px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(212,175,55,0.05);
  }
  .card-img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--surface2);
    position: relative;
  }
  .card-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
  }
  .product-card:hover .card-img-wrap img { transform: scale(1.07); }
  .card-body { padding: 18px 20px 20px; }
  .card-cat {
    font-size: 8px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(212,175,55,0.45);
    display: block;
    margin-bottom: 6px;
    font-weight: 400;
  }
  .card-name {
    font-size: 13px;
    font-weight: 300;
    color: var(--text);
    line-height: 1.45;
    margin-bottom: 6px;
    letter-spacing: 0.01em;
  }
  .card-desc {
    font-size: 11px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .card-price {
    font-size: 20px;
    font-weight: 300;
    color: var(--gold);
    letter-spacing: -0.01em;
  }
  .card-price sup { font-size: 11px; vertical-align: super; }
  .add-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--muted);
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    padding: 9px 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }
  .add-btn:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
    background: rgba(212,175,55,0.04);
  }
  .add-btn.added {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(212,175,55,0.08);
  }

  /* ── CART DRAWER ── */
  #cart-drawer {
    background: rgba(8,8,8,0.97);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-left: 1px solid var(--border);
  }

  /* ── TOAST ── */
  @keyframes toast-in { from { transform: translateY(-12px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  #toast { animation: toast-in 0.25s ease; }

  /* ── QTY BTNS ── */
  .qty-btn {
    width: 28px; height: 28px;
    border: 1px solid var(--surface2);
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; line-height: 1;
    transition: all 0.2s;
    cursor: pointer;
    background: transparent;
    font-family: 'Outfit', sans-serif;
  }
  .qty-btn:hover { border-color: var(--gold); color: var(--gold); }

  /* ── SKELETON ── */
  .skeleton {
    background: linear-gradient(90deg, #111 25%, #1a1a1a 50%, #111 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* ── NAV MOBILE ── */
  #mobile-menu { display: none; }
  #mobile-menu.open { display: flex; }

  /* ── MISC ── */
  .scrollbar-hide { scrollbar-width: none; -ms-overflow-style: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  @keyframes pulse-gold {
    0%,100% { box-shadow: 0 0 0 0 rgba(212,175,55,0.4); }
    50% { box-shadow: 0 0 0 8px rgba(212,175,55,0); }
  }
  #cart-toggle.pulse { animation: pulse-gold 0.6s ease; }

  /* ── PRODUCT COUNT BAR ── */
  #product-count {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 28px;
    padding: 0 4px;
  }

  /* ── DETAIL / CHECKOUT MODAL ── */
  .modal-glass {
    background: rgba(8,8,8,0.92);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid var(--border);
  }

  /* Form inputs */
  .form-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--text);
    padding: 12px 16px;
    font-size: 13px;
    font-family: 'Outfit', sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }
  .form-input:focus { border-color: rgba(212,175,55,0.35); }
  .form-input::placeholder { color: var(--dim); }

  /* Product grid section label */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
    margin-top: 60px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .section-divider.visible { opacity: 1; transform: translateY(0); }
  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .section-divider-label {
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--dim);
    white-space: nowrap;
  }

  /* Back to top indicator */
  #scroll-to-top {
    position: fixed;
    bottom: 36px;
    left: 32px;
    z-index: 40;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  #scroll-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }
  #scroll-to-top button {
    width: 40px; height: 40px;
    border: 1px solid var(--border);
    background: rgba(8,8,8,0.8);
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(12px);
  }
  #scroll-to-top button:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
  }
</style>

<!-- CURSOR -->
<div id="cursor-ring"></div>
<div id="cursor-dot"></div>

<!-- SCROLL PROGRESS -->
<div id="scroll-progress"></div>

<!-- SCROLL TO TOP -->
<div id="scroll-to-top">
  <button onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Retour en haut">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
    </svg>
  </button>
</div>

<!-- TOAST -->
<div id="toast" class="fixed top-24 right-5 z-[70] bg-[#111] border border-[#d4af37]/20 text-white text-xs px-5 py-3 hidden max-w-xs" style="font-family:'Outfit',sans-serif;letter-spacing:0.05em;">
  <span id="toast-msg"></span>
</div>

<!-- NAV -->
<nav id="main-nav" class="fixed top-0 w-full z-50 border-b border-white/5 backdrop-blur-md bg-[#080808]/85">
  <div class="nav-inner flex justify-between items-center h-[72px] px-6 max-w-[1280px] mx-auto" style="height:72px">
    <a href={`${BASE}`} style="font-family:'Outfit',sans-serif;font-weight:200;letter-spacing:0.22em;font-size:12px;text-transform:uppercase;color:#f0ebe2;">
      Atelier Prestige
    </a>
    <div class="hidden md:flex gap-8 items-center">
      <a href={`${BASE}#expertise`} class="nav-link">Expertise</a>
      <a href={`${BASE}#b2b`} class="nav-link">B2B</a>
      <a href={`${BASE}#contact`} class="nav-link">Contact</a>
      <a href={`${BASE}boutique`} style="font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:#d4af37;border:1px solid rgba(212,175,55,0.3);padding:8px 18px;font-family:'Outfit',sans-serif;font-weight:400;transition:background 0.3s ease;" onmouseover="this.style.background='rgba(212,175,55,0.08)'" onmouseout="this.style.background='transparent'">Boutique</a>
    </div>
    <div class="flex items-center gap-3">
      <a href={`${BASE}#contact`} class="hidden md:flex" style="font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(240,235,226,0.5);background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);padding:8px 18px;font-family:'Outfit',sans-serif;transition:all 0.3s ease;" onmouseover="this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
        Devis
      </a>
      <button id="nav-toggle" class="md:hidden text-white/50 hover:text-white w-8 h-8 flex items-center justify-center" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="absolute top-[72px] left-0 right-0 bg-[#080808] border-b border-white/5 flex-col px-6 py-4 gap-4 md:hidden">
    <a href={`${BASE}#expertise`} class="text-[9px] tracking-[0.2em] uppercase text-white/40 py-2 block">Expertise</a>
    <a href={`${BASE}#b2b`} class="text-[9px] tracking-[0.2em] uppercase text-white/40 py-2 block">B2B</a>
    <a href={`${BASE}#contact`} class="text-[9px] tracking-[0.2em] uppercase text-white/40 py-2 block">Contact</a>
    <a href={`${BASE}boutique`} class="text-[9px] tracking-[0.2em] uppercase text-[#d4af37] py-2 block">Boutique</a>
    <a href={`${BASE}#contact`} class="text-[9px] tracking-[0.25em] uppercase text-white/50 py-2 block">Devis personnalisé</a>
  </div>
</nav>

<style is:inline>
  .nav-link {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(240,235,226,0.4);
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    transition: color 0.3s ease;
    text-decoration: none;
  }
  .nav-link:hover { color: rgba(240,235,226,0.85); }
</style>

<main class="min-h-screen" style="background:#080808">

  <!-- ── HERO ── -->
  <section id="hero" class="pt-[72px] px-6 text-center">
    <!-- bg decorative numbers -->
    <span class="hero-bg-num" style="top:8%;left:-2%;transform:rotate(-3deg)">01</span>
    <span class="hero-bg-num" style="bottom:5%;right:-3%;transform:rotate(4deg)">24</span>

    <div style="max-width:1280px;margin:0 auto;display:flex;flex-direction:column;align-items:center;">
      <span class="hero-eyebrow" id="hero-eyebrow">Atelier × WeLuxEvents &nbsp;·&nbsp; Luxembourg</span>

      <div class="hero-title-wrap" style="margin-bottom:0">
        <span class="hero-title" id="hero-title">La Boutique</span>
      </div>

      <div class="hero-line" id="hero-line"></div>

      <p class="hero-subtitle" id="hero-subtitle">
        Broderie &nbsp;·&nbsp; Gravure laser &nbsp;·&nbsp; Découpe vinyle
      </p>

      <div class="hero-tags" id="hero-tags">
        <span class="hero-tag">🐾 Mascotas</span>
        <span class="hero-tag">👶 Baby Shower</span>
        <span class="hero-tag">💛 Mémorias</span>
        <span class="hero-tag">✨ Personnalisation</span>
      </div>

      <div style="margin-top:60px;display:flex;gap:40px;padding-bottom:60px;opacity:0;" id="hero-stats">
        <div style="text-align:center">
          <div style="font-size:clamp(28px,4vw,42px);font-weight:100;color:#f0ebe2;letter-spacing:-0.02em;line-height:1">24</div>
          <div style="font-size:8px;letter-spacing:0.3em;text-transform:uppercase;color:#333;margin-top:6px">Créations</div>
        </div>
        <div style="width:1px;background:rgba(255,255,255,0.06)"></div>
        <div style="text-align:center">
          <div style="font-size:clamp(28px,4vw,42px);font-weight:100;color:#f0ebe2;letter-spacing:-0.02em;line-height:1">4</div>
          <div style="font-size:8px;letter-spacing:0.3em;text-transform:uppercase;color:#333;margin-top:6px">Collections</div>
        </div>
        <div style="width:1px;background:rgba(255,255,255,0.06)"></div>
        <div style="text-align:center">
          <div style="font-size:clamp(28px,4vw,42px);font-weight:100;color:#d4af37;letter-spacing:-0.02em;line-height:1">LU</div>
          <div style="font-size:8px;letter-spacing:0.3em;text-transform:uppercase;color:#333;margin-top:6px">Luxembourg</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FILTER BAR ── -->
  <div id="filter-bar">
    <div id="filter-inner">
      <button data-cat="all"      class="filter-btn active">Tout</button>
      <button data-cat="pets"     class="filter-btn">🐾 Mascotas</button>
      <button data-cat="baby"     class="filter-btn">👶 Baby Shower</button>
      <button data-cat="memories" class="filter-btn">💛 Mémorias</button>
      <button data-cat="custom"   class="filter-btn">✨ Personnalisation</button>
    </div>
  </div>

  <!-- ── PRODUCT GRID ── -->
  <div class="max-w-[1280px] mx-auto px-5 mt-12 pb-40">
    <p id="product-count"></p>
    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      <div class="skeleton h-80"></div>
      <div class="skeleton h-80"></div>
      <div class="skeleton h-80"></div>
      <div class="skeleton h-80"></div>
    </div>
  </div>

