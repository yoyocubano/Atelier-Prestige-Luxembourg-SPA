---
import Layout from "../layouts/Layout.astro";
import "../styles/site.css";

const pageTitle = "Atelier Prestige Luxembourg | Haute Personnalisation Artisanal";
const pageDescription = "High-end bespoke craftsmanship, cadeaux corporatifs et personnalisation de luxe pour entreprises et mariages au Luxembourg.";
---

<Layout title={pageTitle} description={pageDescription} lang="fr">
<style>
        .glass {
            background: rgba(26, 26, 26, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .gold-gradient-border {
            border: 1px solid transparent;
            background-image: linear-gradient(rgba(19, 19, 19, 1), rgba(19, 19, 19, 1)), radial-gradient(circle at top left, #d4af37, #f9e392);
            background-origin: border-box;
            background-clip: content-box, border-box;
        }
        .gold-shine {
            position: relative;
            overflow: hidden;
        }
        .gold-shine::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
            transform: rotate(45deg);
            transition: 0.5s;
        }
        .gold-shine:hover::after {
            left: 100%;
            top: 100%;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
    </style>
<!-- TopNavBar -->
<nav id="top" class="fixed top-0 w-full z-50 border-b border-outline-variant/30 backdrop-blur-md bg-surface/60 h-20">
<div class="flex justify-between items-center h-full px-margin-desktop max-w-container-max mx-auto">
<a class="font-headline-sm text-headline-sm font-bold text-primary tracking-tighter" href="#top">
                Atelier Prestige
            </a>
<div class="hidden md:flex gap-8 items-center">
<a class="font-label-caps text-label-caps uppercase tracking-widest text-on-surface hover:text-primary transition-colors duration-300" href="#expertise">Expertise</a>
<a class="font-label-caps text-label-caps uppercase tracking-widest text-on-surface hover:text-primary transition-colors duration-300" href="#b2b">B2B</a>
<a class="font-label-caps text-label-caps uppercase tracking-widest text-on-surface hover:text-primary transition-colors duration-300" href="#calculateur">Calculateur</a>
<a class="font-label-caps text-label-caps uppercase tracking-widest text-on-surface hover:text-primary transition-colors duration-300" href="#contact">Contact</a>
</div>
<div class="flex items-center gap-6">
<span class="material-symbols-outlined text-primary cursor-pointer hover:scale-105 transition-transform">language</span>
<a class="bg-primary-container text-on-primary-container font-label-caps text-label-caps px-6 py-3 tracking-widest hover:scale-105 transition-transform duration-200" href="#contact">
                    DEVIS
                </a>
</div>
</div>
</nav>
<main>
<!-- Hero Section -->
<section class="relative min-h-screen flex items-center pt-20 overflow-hidden bg-[#0d0d0d]">
<!-- Subtle particles/light leak simulation -->
<div class="absolute inset-0 opacity-20 pointer-events-none">
<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 blur-[120px] rounded-full" />
<div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-primary/10 blur-[150px] rounded-full" />
</div>
<div class="px-margin-desktop max-w-container-max mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-gutter relative z-10">
<div class="md:col-span-8 flex flex-col items-start space-y-8">
<span class="font-label-caps text-label-caps tracking-[0.3em] text-primary uppercase">Maison de Luxe Luxembourg</span>
<h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-background leading-tight">
                        L'Art de la <br /><span class="italic font-normal">Personnalisation</span>
</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl">
                        High-End Bespoke Craftsmanship for Corporates and Weddings in Luxembourg. We transform exceptional objects into eternal memories.
                    </p>
<div class="pt-4">
<a class="gold-shine bg-primary text-on-primary-fixed px-10 py-5 font-label-caps text-label-caps tracking-widest hover:scale-105 transition-all duration-300" href="#contact">
                            REQUEST A BESPOKE QUOTE
                        </a>
</div>
</div>
</div>
<!-- Hero Image Background Overlay -->
<div class="absolute right-0 top-0 w-1/2 h-full opacity-40 md:opacity-100 mix-blend-lighten pointer-events-none">
<picture>
<source srcset="assets/15881da53d29331ca996485b056684b3.webp" type="image/webp" />
<img class="w-full h-full object-cover" alt="Mains d'artisan travaillant le cuir avec des outils dorés dans un atelier de luxe." src="assets/15881da53d29331ca996485b056684b3.webp" loading="eager" />
</picture>
</div>
</section>
<!-- Expertise Section -->
<section class="py-24 bg-background" id="expertise">
<div class="px-margin-desktop max-w-container-max mx-auto">
<div class="mb-16">
<h2 class="font-headline-md text-headline-md text-on-background mb-4">Savoir-Faire</h2>
<div class="h-px w-24 bg-primary" />
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
<!-- Card 1 -->
<div class="glass overflow-hidden border border-outline-variant/30 group hover:scale-[1.02] transition-all duration-500 hover:gold-gradient-border flex flex-col h-full">
<div class="relative overflow-hidden aspect-video">
<picture>
<source srcset="assets/photography_art.webp" type="image/webp" />
<img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="assets/photography_art.webp" alt="Photographie & Direction d'Art" loading="lazy" />
</picture>
<div class="absolute top-4 left-4 glass p-2.5 rounded-full border border-primary/20 flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-2xl">photo_camera</span>
</div>
</div>
<div class="p-8 flex flex-col flex-grow">
<h3 class="font-headline-sm text-headline-sm mb-4">Photographie & Direction d'Art</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-6 flex-grow">Reportages d'art, direction visuelle haut de gamme et tirages de prestige pour sublimer l'image de votre marque ou de vos événements.</p>
<a class="font-label-caps text-label-caps text-primary tracking-widest group-hover:underline underline-offset-4 mt-auto" href="#contact">DÉCOUVRIR</a>
</div>
</div>
<!-- Card 2 -->
<div class="glass overflow-hidden border border-outline-variant/30 group hover:scale-[1.02] transition-all duration-500 hover:gold-gradient-border flex flex-col h-full">
<div class="relative overflow-hidden aspect-video">
<picture>
<source srcset="assets/laser_engraving.webp" type="image/webp" />
<img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="assets/laser_engraving.webp" alt="Gravure Laser de Haute Précision" loading="lazy" />
</picture>
<div class="absolute top-4 left-4 glass p-2.5 rounded-full border border-primary/20 flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-2xl">precision_manufacturing</span>
</div>
</div>
<div class="p-8 flex flex-col flex-grow">
<h3 class="font-headline-sm text-headline-sm mb-4">Gravure Laser de Haute Précision</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-6 flex-grow">Une finesse chirurgicale pour marquer le métal, le verre ou le bois précieux de vos créations.</p>
<a class="font-label-caps text-label-caps text-primary tracking-widest group-hover:underline underline-offset-4 mt-auto" href="#contact">DÉCOUVRIR</a>
</div>
</div>
<!-- Card 3 -->
<div class="glass overflow-hidden border border-outline-variant/30 group hover:scale-[1.02] transition-all duration-500 hover:gold-gradient-border flex flex-col h-full">
<div class="relative overflow-hidden aspect-video">
<picture>
<source srcset="assets/organic_embroidery.webp" type="image/webp" />
<img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="assets/organic_embroidery.webp" alt="Broderie Organique Fine" loading="lazy" />
</picture>
<div class="absolute top-4 left-4 glass p-2.5 rounded-full border border-primary/20 flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-2xl">gesture</span>
</div>
</div>
<div class="p-8 flex flex-col flex-grow">
<h3 class="font-headline-sm text-headline-sm mb-4">Broderie Organique Fine</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-6 flex-grow">Des fils de soie et d'or pour des textiles d'exception au toucher naturel et durable.</p>
<a class="font-label-caps text-label-caps text-primary tracking-widest group-hover:underline underline-offset-4 mt-auto" href="#contact">DÉCOUVRIR</a>
</div>
</div>
<!-- Card 4 -->
<div class="glass overflow-hidden border border-outline-variant/30 group hover:scale-[1.02] transition-all duration-500 hover:gold-gradient-border flex flex-col h-full">
<div class="relative overflow-hidden aspect-video">
<picture>
<source srcset="assets/bespoke_leather.webp" type="image/webp" />
<img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="assets/bespoke_leather.webp" alt="Maroquinerie sur Mesure" loading="lazy" />
</picture>
<div class="absolute top-4 left-4 glass p-2.5 rounded-full border border-primary/20 flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-2xl">work</span>
</div>
</div>
<div class="p-8 flex flex-col flex-grow">
<h3 class="font-headline-sm text-headline-sm mb-4">Maroquinerie sur Mesure</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-6 flex-grow">Travail artisanal des cuirs les plus nobles pour des pièces uniques gravées et dorées.</p>
<a class="font-label-caps text-label-caps text-primary tracking-widest group-hover:underline underline-offset-4 mt-auto" href="#contact">DÉCOUVRIR</a>
</div>
</div>
</div>
</div>
</section>
<!-- B2B Section -->
<section class="py-24 bg-surface-container-lowest" id="b2b">
<div class="px-margin-desktop max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
<div class="relative aspect-[4/5] md:order-last">
<picture>
<source srcset="assets/9415d8ee05c31c7f7bb84a5138b6479c.webp" type="image/webp" />
<img class="w-full h-full object-cover" alt="Bureau corporate luxembourgeois avec cadeaux d'affaires personnalisés." src="assets/9415d8ee05c31c7f7bb84a5138b6479c.webp" loading="lazy" />
</picture>
<div class="absolute -bottom-8 -left-8 p-8 glass border border-primary/20 max-w-xs">
<p class="font-headline-sm text-headline-sm text-primary mb-2">Kirchberg &amp; Cloche d'Or</p>
<p class="font-body-md text-body-md">Service premium dédié aux institutions financières et cabinets de prestige.</p>
</div>
</div>
<div>
<span class="font-label-caps text-label-caps text-primary tracking-widest block mb-4 uppercase">Partenaire Corporate</span>
<h2 class="font-display-lg text-display-lg-mobile md:text-headline-md lg:text-display-lg mb-8">L'Excellence au Service de votre Image</h2>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-8">
                        De l'onboarding pack personnalisé pour vos nouveaux talents aux cadeaux d'affaires exclusifs pour vos clients les plus précieux, l'Atelier Prestige sublime chaque interaction.
                    </p>
<ul class="space-y-4 mb-10">
<li class="flex items-center gap-4 font-body-md text-body-md">
<span class="material-symbols-outlined text-primary">verified</span> Conciergerie Dédiée
                        </li>
<li class="flex items-center gap-4 font-body-md text-body-md">
<span class="material-symbols-outlined text-primary">verified</span> Logistique Sécurisée Luxembourg-City
                        </li>
<li class="flex items-center gap-4 font-body-md text-body-md">
<span class="material-symbols-outlined text-primary">verified</span> Personnalisation à l'unité ou en série
                        </li>
</ul>
<a class="border border-primary text-primary px-8 py-4 font-label-caps text-label-caps tracking-widest flex items-center gap-3 hover:bg-primary hover:text-on-primary transition-all duration-300" href="#contact">
<span class="material-symbols-outlined">download</span> DOWNLOAD PDF CATALOG
                    </a>
</div>
</div>
</section>
<!-- Pricing Calculator -->
<section class="py-24 bg-background" id="calculateur">
<div class="px-margin-desktop max-w-container-max mx-auto">
<div class="text-center mb-16">
<h2 class="font-headline-md text-headline-md text-on-background">Estimateur de Projet</h2>
<p class="font-body-md text-body-md text-on-surface-variant mt-2">Configurez votre demande sur-mesure en quelques clics.</p>
</div>
<div class="max-w-4xl mx-auto glass p-8 md:p-12 border border-outline-variant/30">
<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
<!-- Controls -->
<div class="space-y-8">
<div>
<label class="font-label-caps text-label-caps tracking-widest mb-4 block">Service</label>
<select class="w-full bg-transparent border-b border-outline-variant text-on-surface py-3 focus:border-primary outline-none appearance-none" id="calc-service">
<option class="bg-surface" value="50">Gravure Laser (Base 50€)</option>
<option class="bg-surface" value="80">Maroquinerie (Base 80€)</option>
<option class="bg-surface" value="40">Broderie (Base 40€)</option>
</select>
</div>
<div>
<label class="font-label-caps text-label-caps tracking-widest mb-4 block">Quantité</label>
<select class="w-full bg-transparent border-b border-outline-variant text-on-surface py-3 focus:border-primary outline-none appearance-none" id="calc-units">
<option class="bg-surface" value="1">1 - 10 unités (Tarif plein)</option>
<option class="bg-surface" value="0.9">11 - 50 unités (-10%)</option>
<option class="bg-surface" value="0.8">50+ unités (-20%)</option>
</select>
</div>
<div>
<label class="font-label-caps text-label-caps tracking-widest mb-4 block">Livraison</label>
<div class="flex gap-4">
<label class="flex-1 cursor-pointer">
<input checked="" class="hidden peer" name="delivery" type="radio" value="0" />
<div class="p-4 border border-outline-variant text-center peer-checked:border-primary peer-checked:text-primary transition-all">Standard</div>
</label>
<label class="flex-1 cursor-pointer">
<input class="hidden peer" name="delivery" type="radio" value="30" />
<div class="p-4 border border-outline-variant text-center peer-checked:border-primary peer-checked:text-primary transition-all">Express 24h (+30€)</div>
</label>
</div>
</div>
</div>
<!-- Result -->
<div class="flex flex-col justify-center items-center bg-surface-container-low p-8 border-l border-outline-variant/20">
<span class="font-label-caps text-label-caps tracking-widest text-on-surface-variant mb-4">TOTAL ESTIMÉ</span>
<div class="flex items-baseline gap-2">
<span class="font-display-lg text-display-lg text-primary tracking-tighter" id="calc-result">50.00</span>
<span class="text-2xl font-headline-sm text-primary">€</span>
</div>
<p class="text-center font-body-md text-body-md text-on-surface-variant mt-8 italic">
                                *Ce montant est une estimation hors taxes. Une étude technique sera réalisée lors de la validation.
                            </p>
<button id="calc-book-btn" class="mt-8 w-full bg-primary text-on-primary-fixed py-4 font-label-caps text-label-caps tracking-widest hover:bg-primary-fixed transition-colors">
                                RÉSERVER CE CRÉNEAU
                            </button>
</div>
</div>
</div>
</div>
</section>
<!-- Contact Section -->
<section class="py-24 bg-surface-container-lowest relative overflow-hidden" id="contact">
<div class="px-margin-desktop max-w-container-max mx-auto flex flex-col items-center">
<div class="text-center mb-16 max-w-2xl">
<h2 class="font-headline-md text-headline-md mb-4">Entrez dans l'Atelier</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Confiez-nous votre vision. Notre équipe reviendra vers vous sous 24h pour une consultation privée.</p>
</div>
<form id="contact-form" class="w-full max-w-xl space-y-12">
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="relative">
<input id="contact-name" class="w-full bg-transparent border-0 border-b border-outline text-on-surface py-2 focus:ring-0 focus:border-primary placeholder:text-outline-variant transition-all outline-none" placeholder="Nom Complet" type="text" required />
</div>
<div class="relative">
<input id="contact-email" class="w-full bg-transparent border-0 border-b border-outline text-on-surface py-2 focus:ring-0 focus:border-primary placeholder:text-outline-variant transition-all outline-none" placeholder="Email Professionnel" type="email" required />
</div>
</div>
<div class="relative">
<input id="contact-company" class="w-full bg-transparent border-0 border-b border-outline text-on-surface py-2 focus:ring-0 focus:border-primary placeholder:text-outline-variant transition-all outline-none" placeholder="Entreprise / Événement" type="text" />
</div>
<div class="relative">
<textarea id="contact-description" class="w-full bg-transparent border-0 border-b border-outline text-on-surface py-2 focus:ring-0 focus:border-primary placeholder:text-outline-variant transition-all resize-none outline-none" placeholder="Décrivez votre projet..." rows="4" required></textarea>
</div>
<label class="flex items-start gap-3 font-body-md text-body-md text-on-surface-variant">
<input id="contact-whatsapp-consent" class="mt-2" type="checkbox" />
<span>J'accepte de transférer les informations saisies vers WhatsApp (Meta) si je choisis l'envoi direct par WhatsApp.</span>
</label>
<div class="flex justify-center">
<button id="contact-submit-btn" class="gold-shine group px-16 py-5 bg-primary text-on-primary-fixed font-label-caps text-label-caps tracking-widest hover:scale-105 transition-all duration-300 flex items-center gap-3" type="submit">
                            ENVOYER MA DEMANDE
                            <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_right_alt</span>
</button>
</div>
</form>
</div>

<!-- Floating Premium Glassmorphic Toast -->
<div id="toast-notification" class="fixed bottom-8 right-8 z-50 transform translate-y-24 opacity-0 pointer-events-none transition-all duration-500 glass gold-gradient-border px-8 py-5 shadow-2xl flex items-center gap-4 max-w-md">
<div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center border border-primary/30">
<span id="toast-icon" class="material-symbols-outlined text-primary text-2xl">verified</span>
</div>
<div>
<p id="toast-title" class="font-headline-sm text-[16px] font-bold text-primary tracking-wide">CONFIRMATION</p>
<p id="toast-message" class="font-body-md text-[14px] text-on-surface/90 mt-0.5">Demande enregistrée avec succès.</p>
</div>
</div>
</section>
</main>
<!-- Footer -->
<footer class="w-full border-t border-outline-variant/20 bg-surface-container-lowest">
<div class="py-16 px-margin-desktop max-w-container-max mx-auto flex flex-col md:flex-row justify-between items-center gap-gutter">
<div class="text-center md:text-left">
<div class="font-display-lg text-display-lg text-primary mb-4 scale-75 origin-left">Atelier Prestige</div>
<p class="font-body-md text-body-md text-on-surface-variant">© 2024 Atelier Prestige Luxembourg. Haute Personnalisation Artisanal.</p>
</div>
<div class="flex flex-wrap justify-center gap-8">
<a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors duration-300" href="#contact">Mentions Légales</a>
<a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors duration-300" href="#contact">Confidentialité</a>
<a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors duration-300" href="#b2b">Luxembourg-City</a>
<a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors duration-300" href="#b2b">Kirchberg</a>
</div>
<div class="flex gap-4">
<a class="text-on-surface-variant hover:text-primary transition-colors" href="#expertise" aria-label="Voir les services photo"><span class="material-symbols-outlined">camera</span></a>
<a class="text-on-surface-variant hover:text-primary transition-colors" href="#b2b" aria-label="Voir les services corporate"><span class="material-symbols-outlined">business</span></a>
</div>
</div>
</footer>

<script src="../scripts/atelier.js"></script>
</Layout>
