---
interface Props {
	title: string;
	description?: string;
	image?: string;
	lang?: string;
}

const { 
	title, 
	description = "Atelier Prestige Luxembourg. Artisanat numérique, cadeaux corporatifs et personnalisation de luxe.",
	image = "https://cosmopolita-app-1234--atelier-spa.web.app/assets/15881da53d29331ca996485b056684b3.webp",
	lang = "fr"
} = Astro.props;
---

<!doctype html>
<html class="dark" lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="fb:app_id" content="1234567890" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://cosmopolita-app-1234--atelier-spa.web.app/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://cosmopolita-app-1234--atelier-spa.web.app/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />
	</head>
	<body class="bg-background text-on-surface selection:bg-primary selection:text-on-primary">
		<slot />
	</body>
</html>
